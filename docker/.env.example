# Copy to .env and fill in. Do NOT commit real values.

# --- MongoDB ---
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=changeme
MONGO_DATABASE=grafana_pdc
MONGO_PORT=27017

# --- Grafana Cloud OTLP (Alloy export target) ---
# From Grafana Cloud → Connections → OTLP Endpoint / "Configure"
GCLOUD_OTLP_ENDPOINT=
GCLOUD_OTLP_USERNAME=
GCLOUD_RW_API_KEY=
GCLOUD_LOKI_ENDPOINT=
GCLOUD_LOKI_USERNAME=
GCLOUD_MIMIR_ENDPOINT=
GCLOUD_MIMIR_USERNAME=

# --- Grafana Cloud PDC agent ---
# From Grafana Cloud → Connections → Private data source connections → Configuration Details
GCLOUD_PDC_SIGNING_TOKEN=
GCLOUD_HOSTED_GRAFANA_ID=
GCLOUD_PDC_CLUSTER=

# --- MongoDB MCP server ---
# Defaults to the local mongodb service if unset.
MDB_MCP_CONNECTION_STRING=
MDB_MCP_EXTERNALLY_MANAGED_SESSIONS=true
MDB_MCP_LOG_LEVEL=info
MDB_MCP_PORT=3000

# --- node-app HTTP interface ---
NODE_APP_PORT=8080

# --- go-app HTTP interface ---
GO_APP_PORT=8081

# --- springboot-app HTTP interface ---
SPRINGBOOT_APP_PORT=8082
